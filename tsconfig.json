{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "lib": [
      "DOM",
      "ES2022"
    ],
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/components/items/**",
    "src/components/layout/**",
    "src/components/ui/resizable.tsx",
    "src/features/dashboard/**",
    "src/features/editors/**",
    "src/stores/**",
    "src/data/imported/**",
    "src/lib/db/tauri-fs-adapter.ts",
    "src/lib/exporters/**",
    "src/lib/importers/**",
    "src/lib/platform/**",
    "src/lib/sync/**"
  ]
}
